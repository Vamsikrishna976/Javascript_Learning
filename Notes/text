DAY 23: HIGHER-ORDER FUNCTIONS
EXPLANATION:
  Functions that operate on other functions. Already learned callbacks, now formalize it.
  
  FUNCTIONS THAT ACCEPT FUNCTIONS:
    const numbers = [1, 2, 3, 4, 5];
    
    // map: transform each element
    const doubled = numbers.map(n => n * 2);
    // [2, 4, 6, 8, 10]
    
    // filter: keep elements where condition true
    const evens = numbers.filter(n => n % 2 === 0);
    // [2, 4]
    
    // reduce: combine into single value
    const sum = numbers.reduce((total, n) => total + n, 0);
    // 15
  
  REDUCE EXPLAINED (most complex):
    reduce takes a callback: (accumulator, current) => ...
    
    Example:
      [1, 2, 3].reduce((total, n) => total + n, 0)
      
      Step 1: total = 0 (initial), n = 1, return 0 + 1 = 1
      Step 2: total = 1, n = 2, return 1 + 2 = 3
      Step 3: total = 3, n = 3, return 3 + 3 = 6
      Result: 6
  
  FUNCTIONS THAT RETURN FUNCTIONS:
    function makeValidator(min, max) {
      return function(value) {
        return value >= min && value <= max;
      };
    }
    
    const isAdult = makeValidator(18, 150);
    isAdult(25); // true
    isAdult(10); // false
  
  COMPOSING FUNCTIONS:
    function compose(...functions) {
      return function(value) {
        return functions.reduceRight((val, fn) => fn(val), value);
      };
    }
    
    const add1 = x => x + 1;
    const double = x => x * 2;
    
    const addThenDouble = compose(double, add1);
    addThenDouble(3); // (3 + 1) * 2 = 8
  
  PRACTICAL EXAMPLE:
    function filter(array, condition) {
      return array.filter(condition);
    }
    
    const isPositive = n => n > 0;
    filter([1, -2, 3, -4], isPositive); // [1, 3]

