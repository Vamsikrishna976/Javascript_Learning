DAY 25: PROMISE CHAIN
EXPLANATION:
  Chaining promises to handle sequential async operations.
  
  BASIC CHAINING:
    fetchUser(1)
      .then(user => {
        console.log("Got user:", user);
        return fetchPosts(user.id);  // return another promise
      })
      .then(posts => {
        console.log("Got posts:", posts);
        return filterPosts(posts);   // return another promise
      })
      .then(filtered => {
        console.log("Filtered posts:", filtered);
      })
      .catch(error => {
        console.log("Error:", error);
      });
  
  KEY POINTS:
    1. Each .then() receives previous result
    2. Return a promise from .then() to chain
    3. Return a value to pass it to next .then()
    4. One .catch() catches errors from any step
  
  COMPARISON: OLD WAY (CALLBACK HELL)
    fetchUser(1, function(err, user) {
      if (err) {
        handleError(err);
      } else {
        fetchPosts(user.id, function(err, posts) {
          if (err) {
            handleError(err);
          } else {
            console.log(posts);
          }
        });
      }
    });
  
  TRANSFORMING DATA IN CHAIN:
    fetch('https://api.example.com/user/1')
      .then(response => response.json())  // convert to JSON
      .then(user => ({
        ...user,
        fullName: user.firstName + ' ' + user.lastName
      }))
      .then(user => console.log(user.fullName))
      .catch(error => console.log("Request failed:", error));
  
  ERROR RECOVERY:
    fetchData()
      .catch(error => {
        console.log("First attempt failed, retrying...");
        return fetchData();  // retry
      })
      .then(data => console.log(data));

